# Node (relatorio de clips/shorts HUD, se houver)
node_modules/
package-lock.json
package.json

# Media / videos / clips (binarios grandes)
videos/
clips/
clips_shorts_hud/
*.mp4
*.mov
*.webm
*.mkv

# Pastas de trabalho (documentos gerados pelos agentes)
estacao/
negocios/
uploads/
*.docx
*.pdf

# OS
.DS_Store
.AppleDouble/
